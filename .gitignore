# Scrapy
.scrapy/

# Data files — organized by lifecycle role:
#   raw/       ingested source data (never committed)
#   reference/ curated inputs (COMMITTED — intentionally not ignored)
#   cache/     regenerable, safe to delete
#   derived/   pipeline outputs (value analysis, area stats, metrics)

# raw: ingested Booli dumps
data/raw/booli/*
!data/raw/booli/.gitkeep

# cache: regenerable, throwaway
data/cache/*
!data/cache/.gitkeep
cache/

# derived: pipeline outputs
data/derived/*
!data/derived/.gitkeep
!data/derived/metrics/
data/derived/metrics/*
!data/derived/metrics/.gitkeep

# Model artifacts (generated during training)
web/models/*
!web/models/.gitkeep

reports/*
!reports/.gitkeep

# Checkpoints
/tmp/pipeline_checkpoint.json
.pipeline_state.json

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints
notebooks/*.csv
notebooks/*.ipynb

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
.tox/

# Build artifacts
dist/
build/
*.egg-info/

# Images (scraped property images)
data/images/

# OpenSpec
openspec/
