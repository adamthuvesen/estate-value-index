# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/

# Testing
.pytest_cache/
.coverage
htmlcov/
tests/
*.test.js

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js (keep .next/ for standalone build, exclude dev cache only)
.next/cache/
out/

# Data files (too large/generated for container)
data/raw/
data/enrichment/*
!data/enrichment/.gitkeep
data/metrics/*
!data/metrics/.gitkeep
*.csv
*.parquet

# Model files (loaded from GCS)
web/models/*
!web/models/.gitkeep

# Notebooks
notebooks/
*.ipynb

# Reports
reports/

# Git
.git/
.gitignore
.gitattributes

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Documentation
*.md
!README.md

# Scripts (exclude all except startup.sh which is needed at runtime)
scripts/*
!scripts/startup.sh

# Environment files
.env
.env.local
.env.*.local

# CI/CD
.github/

# Cache
cache/
.cache/
*.log
