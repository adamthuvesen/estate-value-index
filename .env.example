# Estate Value Index Configuration
# Copy this file to .env and fill in your values

# ==============================================================================
# REQUIRED ENVIRONMENT VARIABLES
# ==============================================================================

# GCP Core Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-north1

# BigQuery Configuration
BIGQUERY_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET_RAW=booli_raw
BIGQUERY_TABLE_LISTINGS=listings
BIGQUERY_DATASET_FEATURES=booli_features
BIGQUERY_TABLE_FEATURES=engineered_features

# GCS Configuration
GCS_BUCKET=your-gcs-bucket

# ==============================================================================
# OPTIONAL ENVIRONMENT VARIABLES (with defaults)
# ==============================================================================

# Data Source Configuration
DATA_SOURCE=bigquery
MAX_MAE_THRESHOLD=260000
MIN_AREA_COUNT=5
DAYS_ON_MARKET_THRESHOLD=1000

# Scraping Configuration
SCRAPER_MAX_PAGES=50
SCRAPER_CONCURRENT_REQUESTS=4
SCRAPER_DELAY_MIN=0.1

# Model Configuration
MODEL_PREFIX=price_prediction_model
MODEL_OUTPUT_DIR=web/models

# Cloud Run Configuration
CLOUD_RUN_SERVICE_NAME=estate-value-index-app
CLOUD_RUN_REGION=europe-north1
CLOUD_RUN_MIN_INSTANCES=1
CLOUD_RUN_MAX_INSTANCES=10

# Vertex AI Configuration
VERTEX_AI_MACHINE_TYPE=n1-standard-4
VERTEX_AI_REGION=europe-north1

# Flags
DEBUG=false
DRY_RUN=false
VERBOSE_LOGGING=true
GCS_ENABLED=false

# ==============================================================================
# SENSITIVE VARIABLES (optional but recommended)
# ==============================================================================

# Prefect Cloud (for orchestration)
# PREFECT_API_KEY=your_prefect_api_key_here

# Slack Notifications (for alerts)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Vertex AI Service Account (for custom jobs)
# VERTEX_AI_SERVICE_ACCOUNT=service-account@PROJECT.iam.gserviceaccount.com

# ==============================================================================
# LEGACY COMPATIBILITY (fallbacks for existing setups)
# ==============================================================================

# These are automatically mapped to the new variable names
# BIGQUERY_DATASET_ID=booli_raw  # Maps to BIGQUERY_DATASET_RAW
# BIGQUERY_TABLE_ID=listings     # Maps to BIGQUERY_TABLE_LISTINGS
